# Protect the VibeKB data directory from direct web access.
# The SQLite database and any journal/lock files live here and must never be
# served over HTTP. Deployed to public_html/site/data/ (served under /site/data/).

Options -Indexes

# Apache 2.4 (mod_authz_core) — the live host (LiteSpeed) understands this syntax.
<FilesMatch "\.(sqlite|sqlite3|db)(-wal|-shm|-journal)?$">
    Require all denied
</FilesMatch>

# Apache 2.2 compatibility fallback, scoped so it only applies where
# mod_authz_core is absent. Never mixed unscoped with the 2.4 directives above.
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(sqlite|sqlite3|db)(-wal|-shm|-journal)?$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>
